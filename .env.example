# ===========================================
# AI Provider Configuration
# ===========================================
# Bfloat IDE supports two AI providers:
#
# 1. Claude (Anthropic)
#    - OAuth: Use your Claude Max subscription via "Connect Claude" in settings
#    - API Key: Set ANTHROPIC_API_KEY below for pay-per-use
#
# 2. Codex (OpenAI)
#    - OAuth: Use your ChatGPT subscription via "Connect ChatGPT" in settings
#    - API Key: Set OPENAI_API_KEY below for pay-per-use

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=

# OpenAI API Key (for Codex models)
OPENAI_API_KEY=

# ===========================================
# MCP Server Integrations (Optional)
# ===========================================
# Enable additional capabilities through MCP servers

# Stripe (payment processing)
STRIPE_SECRET_KEY=

# RevenueCat (in-app purchases)
REVENUECAT_API_KEY=

# ===========================================
# macOS Code Signing & Notarization
# ===========================================
# Required for distributing macOS builds

# Code Signing Certificate Name
CSC_NAME=

# Notarization Credentials
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# ===========================================
# Auto-Updates Distribution
# ===========================================
# Configure S3 bucket for hosting app updates

AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPDATES_BUCKET=
UPDATE_CHANNEL=stable
