# ===========================================
# AI Provider Configuration
# ===========================================
# The IDE supports two authentication modes:
# 1. OAuth (recommended) - Use your existing Claude/ChatGPT subscription
#    - Claude: Run "Connect Claude" in settings to use claude setup-token
#    - ChatGPT: Run "Connect ChatGPT" in settings to use codex login
#
# 2. API Keys (pay-per-use) - Use direct API access
#    Set the appropriate API key for your provider:

# Anthropic API Key (for Claude models via API)
ANTHROPIC_API_KEY=

# OpenAI API Key (for GPT models via API)
OPENAI_API_KEY=

# Alternative AI Providers (optional)
MOONSHOT_API_KEY=      # For KIMI models
MINIMAX_API_KEY=       # For MiniMax models
ZHIPU_API_KEY=         # For ZhipuAI GLM models

# ===========================================
# Integration API Keys (Optional)
# ===========================================
# Stripe API Keys (for Stripe MCP integration)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# RevenueCat API Key (for RevenueCat MCP integration)
REVENUECAT_API_KEY=

# ===========================================
# Optional: Self-Hosted Backend
# ===========================================
# If you're running your own backend for OAuth handling,
# set these URLs. Leave empty to use direct API access.
BACKEND_URL=
VITE_BACKEND_URL=

# ===========================================
# macOS Code Signing (for distribution)
# ===========================================
CSC_NAME=

# macOS Notarization (Option 1: Apple ID - Recommended for CI/CD)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# macOS Notarization (Option 2: API Key - More secure)
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# macOS Notarization (Option 3: Keychain Profile)
APPLE_KEYCHAIN_PROFILE=

# ===========================================
# Auto-Updates (for distribution)
# ===========================================
# AWS S3 for hosting updates (optional)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPDATES_BUCKET=
UPDATE_CHANNEL=stable
UPDATES_PREFIX=

# Or use a custom update URL
UPDATE_BASE_URL=
