{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bfloat IDE",
  "identifier": "com.bfloat.ide",
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://bfloat.dev/api/updates/latest/stable?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
