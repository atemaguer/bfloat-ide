{
  "name": "bfloat-ide",
  "version": "0.2.10",
  "description": "AI-powered IDE for building web and mobile apps with Claude and ChatGPT",
  "main": "./out/main/main.js",
  "license": "MIT",
  "author": {
    "name": "Bfloat, Inc"
  },
  "scripts": {
    "dev": "cross-env ELECTRON_DISABLE_SANDBOX=1 electron-vite dev -w",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps && npx @electron/rebuild",
    "vite:build": "electron-vite build",
    "electron:build:win": "node scripts/ensure-optional-deps.cjs && electron-builder --win",
    "electron:build:mac": "node scripts/ensure-optional-deps.cjs && electron-builder --mac",
    "electron:build:linux": "node scripts/ensure-optional-deps.cjs && electron-builder --linux",
    "electron:build:dir": "electron-builder --dir",
    "build:unpack": "run-s vite:build electron:build:dir",
    "build:win": "run-s vite:build electron:build:win",
    "build:mac": "run-s vite:build electron:build:mac",
    "build:linux": "run-s vite:build electron:build:linux"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bfloat-inc/bfloat-ide"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@ai-sdk-tools/store": "^0.1.2",
    "@anthropic-ai/claude-agent-sdk": "^0.2.6",
    "@anthropic-ai/claude-code": "^2.1.29",
    "@aws-sdk/client-s3": "^3.958.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.4",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/notarize": "^3.1.1",
    "@openai/codex-sdk": "^0.101.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/code": "^1.0.1",
    "@tanstack/react-query": "^5.90.12",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^6.0.62",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "codex-sdk": "^0.2.9",
    "electron-log": "^5.4.3",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.29.2",
    "node-pty": "^1.0.0",
    "qrcode.react": "^4.2.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.0.3",
    "react-router-dom": "^7.10.1",
    "streamdown": "^2.1.0",
    "stripe": "^20.3.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7",
    "use-stick-to-bottom": "^1.1.1",
    "zod": "^4.1.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.2",
    "@eslint/js": "^9.34.0",
    "@rushstack/eslint-patch": "^1.12.0",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@vitejs/plugin-react": "^5.0.1",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.3",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "eslint": "^9.34.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "framer-motion": "^12.23.12",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vite-plugin-node-polyfills": "^0.24.0"
  }
}
