# Stripe
# Get your keys from https://dashboard.stripe.com/apikeys

# Next.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Must include scheme (http:// or https://), e.g. https://app.example.com in production.
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Vite
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Create React App
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Connect Account ID (set automatically in production)
# STRIPE_ACCOUNT_ID=acct_xxx
# NEXT_PUBLIC_STRIPE_ACCOUNT_ID=acct_xxx
