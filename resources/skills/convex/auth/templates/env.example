# Convex
# Use the prefix matching your framework:
#   Expo:    EXPO_PUBLIC_CONVEX_URL
#   Next.js: NEXT_PUBLIC_CONVEX_URL
EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Convex Site URL (for Better Auth HTTP actions)
#   Expo:    EXPO_PUBLIC_CONVEX_SITE_URL
#   Next.js: NEXT_PUBLIC_CONVEX_SITE_URL
# Note: Convex deployment env `SITE_URL` must also be set via `npx convex env set SITE_URL ...`.
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
